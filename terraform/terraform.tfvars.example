
# Example Terraform variables
# Copy this file to terraform.tfvars and customize the values

aws_region      = "us-east-1"
environment     = "dev"
collection_name = "registry-collection"

# Standby replicas: ENABLED or DISABLED
standby_replicas = "DISABLED"

# Network Access Configuration
# Needed for the registry API load balancer and ECS service
vpc_id = "vpc-1234567890abcdef0"
subnet_ids = ["subnet-1234567890abcdef0", "subnet-0987654321fedcba0"]
public_subnet_ids = ["subnet-3234567890abcdef0", "subnet-3987654321fedcba0"]
security_group_ids = []  # Leave empty to create a default security group

# Common tags applied to all resources
common_tags = {
  Project     = "registry"
  Environment = "dev"
  ManagedBy   = "terraform"
  Owner       = "your-team"
}

# Lambda Configuration
# Lambda execution role is now created automatically by the IAM module
# lambda_execution_role_arn is no longer needed
lambda_runtime            = "python3.13"
lambda_timeout            = 30
lambda_memory_size        = 512

# Cognito Configuration for Lambda
cognito_allowed_groups   = ["admin", "read-only", "geo-writers"]
cognito_user_pool_id     = "us-east-1_XXXXXXXXX"
cognito_identity_pool_id = "us-east-1:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# API Gateway Configuration
api_gateway_name       = "pds-registry-api"
api_gateway_stage_name = "prod"
